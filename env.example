# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Uygulama ortamı: development | preview | production
NEXT_PUBLIC_APP_ENV=development
APP_ENV=development

# Sentry hata izleme
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog ürün analitiği
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com


# Supabase sunucu anahtarı (yalnız Vercel server-side; NEXT_PUBLIC_ kullanma)
SUPABASE_SERVICE_ROLE_KEY=

# Uygulamanın herkese açık production adresi
NEXT_PUBLIC_APP_URL=https://alanadiniz.com

# iyzico Checkout Form / Marketplace
IYZIPAY_ENV=sandbox
IYZIPAY_URI=https://sandbox-api.iyzipay.com
IYZIPAY_API_KEY=
IYZIPAY_SECRET_KEY=
IYZIPAY_ENABLED_INSTALLMENTS=1
IYZIPAY_STRICT_WEBHOOK=false
IYZIPAY_REQUIRE_RESPONSE_SIGNATURE=false

# Komisyon oranları: 0.025 = %2,5 / 0.08 = %8
KAPISKAPIS_BUYER_FEE_RATE=0.025
NEXT_PUBLIC_KAPISKAPIS_BUYER_FEE_RATE=0.025
KAPISKAPIS_SELLER_COMMISSION_RATE=0.08

# Akıllı Teklif Güvencesi
# 5.000 TL ve altındaki ilk tekliflerde kart doğrulaması için alınacak küçük tutar.
KAPISKAPIS_CARD_VERIFICATION_AMOUNT=10
